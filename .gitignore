# ## VVisual Studio / Rider / VS Code specific files ###
.vs/
.idea/
*.user
*.suo
*.sln.docstates

# ## Build Folders ###
# Folders containing compiled binaries and intermediate files
[Bb]in/
[Oo]bj/
[Pp]ublish/
**/publish/

# ## Local User Settings ###
# User-specific files should not be committed
*.DotSettings.user
*.userprefs

# ## Local Configuration (DO NOT COMMIT SECRETS) ###
# Local settings file, often contains connection strings or secrets.
# A template like 'appsettings.Development.template.json' can be committed instead.
appsettings.Development.json
secrets.json
*.env

# ## Entity Framework Core ###
# EF Core database migration scripts can be generated on each machine
# Although some teams prefer to commit them. For now, we ignore them.
# If you want to commit migrations, remove the line below.
# Migrations/

# ## OS Generated Files ###
# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
*.[Cc]ache
*.orig

# ## Log and Report Files ###
*.log
*.tmp
*.rpt
log/
logs/

# ## Other ###
*.nupkg
*.nuget.props
*.nuget.targets

# ## Uploaded Files ###
# Ignore all uploaded files in uploads directory
uploads/
**/uploads/

# ## Frontend specific ignores ###
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/
dist/
dist-ssr/
*.local

# Environment variables (additional frontend)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor directories and files (additional)
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sw?